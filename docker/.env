# --- Configurações do Banco de Dados ---
DB_TYPE=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=fluig
DB_USER=fluig
DB_PASSWORD=fluig

# --- Configurações de Performance (JVM) ---
JVM_MAX_HEAP=4096
JVM_MIN_HEAP=2048
JVM_MAX_METASPACE=1024
JVM_MIN_METASPACE=512

# --- Pools de Conexão ---
POOL_EJB=20
POOL_HTTP=200
POOL_MDB=20
POOL_DS_MAX=100
POOL_DS_MIN=10

# --- Configurações do Fluig ---
FLUIG_INSTALL_PATH=/opt/totvs/fluig
FLUIG_URL=http://localhost:8080
FLUIG_UPDATE=false

# --- Módulos (true/false) ---
INSTALL_SOLR=true
INSTALL_NODE=true

# --- Licenciamento ---
LS_HOST=127.0.0.1
LS_PORT=5555

# --- Portas Expostas ---
PORT_APP=8080
PORT_SSL=8443
PORT_SOLR=8983
PORT_REALTIME=8888
PORT_CHAT=7070
PORT_DB=3306

# --- Caminhos locais ---
INSTALLER_PATH=../installer-package
SCRIPTS_PATH=./scripts
